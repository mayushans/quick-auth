# ── Quick Auth — systemd 服务配置 ──
[Unit]
Description=Quick Auth - Email verification based authentication service
After=network.target
Wants=network-online.target

[Service]
Type=exec

# ── 工作目录（项目根目录，确保 .env 文件在此路径下） ──
WorkingDirectory=/opt/quick-auth

# ── 运行用户和组 ──
User=www-data
Group=www-data

# ── 启动命令（使用 tsx 直接运行 TypeScript） ──
ExecStart=/usr/bin/node /opt/quick-auth/dist/index.js

# ── 重启策略 ──
Restart=always
RestartSec=5

# ── 环境变量（也可通过项目根目录的 .env 文件加载） ──
# Environment=NODE_ENV=production
# Environment=PORT=3000

[Install]
WantedBy=multi-user.target
