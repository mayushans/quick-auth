# ── SMTP 邮件配置（用于发送验证码） ──
# 不配置时开发环境会将验证码打印到控制台
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
FROM_EMAIL=noreply@example.com

# ── 会话配置 ──
SESSION_TTL=86400        # 会话有效期，秒（默认 24h）
CODE_TTL=300             # 验证码有效期，秒（默认 5min）
RATE_LIMIT_TTL=60        # 发送频率限制间隔，秒（默认 60s）

# ── 服务 ──
PORT=3000
NODE_ENV=development     # production 时 Cookie 的 Secure 标记启用
AUTH_PUBLIC_URL=https://auth.example.com  # Quick Auth 公网地址，用于重定向

# ── Cookie 共享域名（可选） ──
# 当认证服务器与业务服务在同一父域下时，设置此项可实现跨子域登录态共享。
# 例如 auth.example.com 与 app.example.com 共享 .example.com
# 注意：需要 HTTPS 支持（SameSite=None 强制 Secure 标记）
AUTH_COOKIE_DOMAIN=

